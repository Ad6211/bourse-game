<?xml version='1.0' encoding='utf-8'?>
<widget id="com.boursegame.game" version="1.0.0"
    xmlns="http://www.w3.org/ns/widgets"
    xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Bourse Game</name>
    <description>Jeu de bourse virtuel - Investissez et gagnez!</description>
    <author email="contact@boursegame.com" href="https://boursegame.com">Bourse Game Team</author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <icon src="www/icon.png" />
    <splash src="www/icon.png" />
    <preference name="Orientation" value="portrait" />
    <preference name="Fullscreen" value="false" />
    <preference name="WebViewBounce" value="false" />
    <preference name="android-minSdkVersion" value="22" />
    <preference name="android-targetSdkVersion" value="36" />
</widget>